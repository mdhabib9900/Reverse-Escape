<?xml version='1.0' encoding='utf-8'?>
<widget id="com.reversescape.game" version="1.0.0" xmlns="http://www.w3.org/ns/widgets" xmlns:cdv="http://cordova.apache.org/ns/1.0">
    <name>Reverse Escape</name>
    <description>A retro-style arcade escape game with challenging puzzles and addictive gameplay.</description>
    <author email="dev@reversescape.com" href="https://reversescape.com">Reverse Escape Dev</author>
    <content src="index.html" />
    <access origin="*" />
    <allow-intent href="http://*/*" />
    <allow-intent href="https://*/*" />
    <allow-intent href="tel:*" />
    <allow-intent href="sms:*" />
    <allow-intent href="mailto:*" />
    <allow-intent href="geo:*" />
    <platform name="android">
        <allow-intent href="market:*" />
        <icon src="icons/logo-192x192.png" density="ldpi" />
        <icon src="icons/logo-192x192.png" density="mdpi" />
        <icon src="icons/logo-192x192.png" density="hdpi" />
        <icon src="icons/logo-512x512.png" density="xhdpi" />
        <icon src="icons/logo-512x512.png" density="xxhdpi" />
        <icon src="icons/logo-512x512.png" density="xxxhdpi" />
        <splash src="icons/logo-512x512.png" density="land-ldpi" />
        <splash src="icons/logo-512x512.png" density="land-mdpi" />
        <splash src="icons/logo-512x512.png" density="land-hdpi" />
        <splash src="icons/logo-512x512.png" density="land-xhdpi" />
        <splash src="icons/logo-512x512.png" density="land-xxhdpi" />
        <splash src="icons/logo-512x512.png" density="land-xxxhdpi" />
        <splash src="icons/logo-512x512.png" density="port-ldpi" />
        <splash src="icons/logo-512x512.png" density="port-mdpi" />
        <splash src="icons/logo-512x512.png" density="port-hdpi" />
        <splash src="icons/logo-512x512.png" density="port-xhdpi" />
        <splash src="icons/logo-512x512.png" density="port-xxhdpi" />
        <splash src="icons/logo-512x512.png" density="port-xxxhdpi" />
    </platform>
    <preference name="Orientation" value="portrait" />
    <preference name="FullScreen" value="false" />
    <preference name="ShowTitle" value="true" />
    <preference name="FadeSplashScreen" value="true" />
    <preference name="FadeSplashScreenDuration" value="3000" />
    <preference name="SplashScreenDelay" value="3000" />
    <preference name="BackgroundColor" value="0x0a0a12" />
    <preference name="HideKeyboardFormAccessoryBar" value="true" />
    <preference name="KeyboardDisplayRequiresUserAction" value="false" />
    <preference name="loadUrlTimeoutValue" value="70000" />
    <preference name="AndroidWindowSoftInputMode" value="adjustResize" />
</widget>
